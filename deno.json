{
    "name": "@pinta365/oura-api",
    "version": "1.1.0",
    "exports": {
        ".": "./mod.ts",
        "./mcp/stdio": "./mcp/stdio.ts"
    },
    "publish": {
        "exclude": ["scripts", "examples"]
    },

    "tasks": {
        "build_npm": "deno run -A scripts/build_npm.ts",
        "generate_types": "deno run -A scripts/generate_types.ts",
        "mcp:stdio": "deno run --allow-net --allow-env --allow-read --allow-write --allow-run mcp/stdio.ts"
    },
    "lint": {
        "include": ["src"]
    },
    "fmt": {
        "lineWidth": 120,
        "indentWidth": 4
    }
}
